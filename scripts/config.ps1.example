<#
.SYNOPSIS
    Shared deployment configuration — COPY THIS FILE to config.ps1 and fill in your values.

.DESCRIPTION
    This is a template. To set up:

    1. Copy this file:
           Copy-Item scripts\config.ps1.example scripts\config.ps1

    2. Fill in all <PLACEHOLDER> values in config.ps1

    3. Generate a self-signed certificate and register it with your Entra ID app:
           See scripts/README.md → "Authentication Setup" for step-by-step instructions.

    config.ps1 is gitignored — your tenant-specific values stay local.

.NOTES
    NEVER commit config.ps1 to source control.
    The deploy-cert.pfx private key file must also remain local (gitignored).
#>

# --- Tenant ---
$script:TenantId     = "<your-tenant-id>"               # e.g. "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
$script:TenantName   = "<your-tenant-name>"             # e.g. "contoso" (from contoso.onmicrosoft.com)
$script:TenantDomain = "<your-tenant-name>.onmicrosoft.com"

# --- App registration (created by setup — see scripts/README.md) ---
$script:ClientId       = "<your-entra-app-client-id>"   # App registration client ID
$script:CertThumbprint = "<your-cert-thumbprint>"       # SHA1 thumbprint of deploy cert in Cert:\CurrentUser\My

# --- Well-known URLs (derived from TenantName — no need to change) ---
$script:AdminUrl     = "https://$($script:TenantName)-admin.sharepoint.com"
$script:SiteUrl      = "https://$($script:TenantName).sharepoint.com/sites/exec-workspace"
$script:AdminUPN     = "admin@$($script:TenantDomain)"

# --- Power Platform / Dataverse (WS-5, WS-6) ---
$script:DataverseUrl     = "https://<your-dataverse-org>.crm.dynamics.com"  # Find in: Power Platform admin > Environments > your env > Settings > Resources > Developer resources
$script:PublisherPrefix  = "<your-publisher-prefix>"                         # Find via: pac auth create; then pac solution list (Customization Prefix column)

# --- Helper: silent PnP connection (no browser, no device code) ---
function Connect-WorkspacePnP {
    param([Parameter(Mandatory)][string]$Url)
    Connect-PnPOnline -Url $Url `
        -ClientId   $script:ClientId `
        -Tenant     $script:TenantDomain `
        -Thumbprint $script:CertThumbprint
}

# --- Helper: silent Graph connection (no browser, no device code) ---
function Connect-WorkspaceGraph {
    Connect-MgGraph `
        -ClientId              $script:ClientId `
        -TenantId              $script:TenantId `
        -CertificateThumbprint $script:CertThumbprint `
        -NoWelcome
}

# --- Helper: silent IPPS/SCC connection (cert auth, no browser) ---
# NOTE: Pin ExchangeOnlineManagement to 3.8.x — version 3.9.x bundles an older MSAL.NET
#       that conflicts with Microsoft.Graph 2.x in the same PS session.
#       See scripts/README.md → Known Issues for details.
function Connect-WorkspaceIPPS {
    Import-Module ExchangeOnlineManagement -MaximumVersion 3.8.99 -Force -ErrorAction SilentlyContinue
    Connect-IPPSSession `
        -AppId                  $script:ClientId `
        -CertificateThumbprint  $script:CertThumbprint `
        -Organization           $script:TenantDomain `
        -ShowBanner:$false
}

# --- Helper: silent Exchange Online connection (cert auth, no browser) ---
# NOTE: Same EXO version constraint as Connect-WorkspaceIPPS above.
function Connect-WorkspaceEXO {
    Import-Module ExchangeOnlineManagement -MaximumVersion 3.8.99 -Force -ErrorAction SilentlyContinue
    Connect-ExchangeOnline `
        -AppId                 $script:ClientId `
        -CertificateThumbprint $script:CertThumbprint `
        -Organization          $script:TenantDomain `
        -ShowBanner:$false
}
