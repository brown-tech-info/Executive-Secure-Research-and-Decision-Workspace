            "TableName": "Review",
            "Parameters": {}
        },
        "Approved": {
            "Type": "SharePointLibrary",
            "ConnectorId": "/providers/Microsoft.PowerApps/apis/sharepointonline",
            "DatasetName": "https://{tenant}.sharepoint.com/sites/exec-workspace",
            "TableName": "Approved",
            "Parameters": {}
        },
        "Archive": {
            "Type": "SharePointLibrary",
            "ConnectorId": "/providers/Microsoft.PowerApps/apis/sharepointonline",
